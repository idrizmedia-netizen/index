rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ⚠️ Shu yerga ham admin-guard.js dagi bilan BIR XIL UID'ni yozing
    function ownerUid() {
      return "PhFPRmGQdnVNu3dsepFLem5Xzmg2";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == ownerUid() ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ── Tanlovlar: hammaga ochiq o'qish, faqat admin yozadi ──
    match /contests/{contestId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Ro'yxatdan o'tishlar ──
    match /registrations/{regId} {
      allow get: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.score == null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Barcha saytga kirgan foydalanuvchilar (bloklash uchun ham) ──
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin();
    }

    // ── Bo'limlar qanchalik ishlatilishi (statistika) ──
    match /usage-stats/{featureId} {
      allow read: if isAdmin();
      allow write: if isSignedIn();
    }

    // ── Bosh sahifa kontenti (rasm, matn) — admin tahrirlaydi, hammaga ochiq o'qish ──
    match /site-content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Ketma-ket ID hisoblagich ──
    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Bildirishnomalar: hammaga ochiq o'qish, faqat admin yozadi ──
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Adminlar ro'yxati (UID bo'yicha): kiruvchilar o'qiy oladi, faqat owner o'zgartiradi ──
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == ownerUid();
    }

    // ── Login/parol hisoblari (barcha qurilmalarda ishlashi uchun) ──
    match /local-accounts/{login} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── Ochiq statistika: hammaga o'qish, kirgan foydalanuvchi yangilay oladi ──
    match /stats/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── G'oliblar reytingi: admin e'lon qiladi, hammaga ochiq (shaxsiy ma'lumotsiz) ──
    match /leaderboards/{contestId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
